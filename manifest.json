{
  "id": "com.phoneway.scale",
  "name": "Phoneway Ultra-Precision Scale",
  "short_name": "Phoneway",
  "description": "Professional-grade 0.1g accuracy scale using 15-sensor fusion, neural networks, and machine learning. Self-calibrating and continuously improving.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "window-controls-overlay"],
  "orientation": "portrait",
  "background_color": "#0a0a0a",
  "theme_color": "#c9a227",
  "categories": ["utilities", "tools", "productivity"],
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "icons": [
