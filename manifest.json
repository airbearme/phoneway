  "shortcuts": [
    {
      "name": "Quick Weigh",
      "short_name": "Weigh",
      "url": "./?mode=ultra",
      "description": "Start ultra-precision weighing immediately",
      "icons": [{ "src": "icons/icon-96.png", "sizes": "96x96" }]
    },
    {
      "name": "Calibrate",
      "short_name": "Calibrate",
      "url": "./?cal=true",
      "description": "Calibrate with known weight for maximum accuracy",
      "icons": [{ "src": "icons/icon-96.png", "sizes": "96x96" }]
    },
    {
      "name": "Accuracy Report",
      "short_name": "Stats",
      "url": "./?view=stats",
      "description": "View accuracy metrics and ML training status",
      "icons": [{ "src": "icons/icon-96.png", "sizes": "96x96" }]
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/scale.png",
